---
/**
 * Single tool card — description, parameter table + schema,
 * then response table + schema.
 */
import ParameterTable from "./ParameterTable.astro";

interface Props {
  name: string;
  description: string;
  schema: Record<string, any>;
  tier: "read" | "create" | "edit";
  endpoint?: boolean;
  responseSchema?: Record<string, any>;
  responseExample?: unknown;
}

const { name, description, schema, tier, endpoint, responseSchema, responseExample } = Astro.props;
---

<div class="tool-card">
  <div class="tool-badges">
    {tier !== "read" && <span class={`badge-tier badge-${tier}`}>{tier}</span>}
    {endpoint && <a href="/Vibma/endpoints/" class="badge-tier badge-endpoint">endpoint</a>}
  </div>
  <p class="tool-description">{description}</p>

  <ParameterTable schema={schema} />
  <details class="schema-details">
    <summary>JSON Schema</summary>
    <pre><code>{JSON.stringify(schema, null, 2)}</code></pre>
  </details>

  {responseSchema && (
    <div class="response-section">
      <h4>Response <span class="response-hint">reference only — not included in tool definitions</span></h4>
      <ParameterTable schema={responseSchema} fieldLabel="Field" hideRequired />
      {responseExample !== undefined && (
        <details class="schema-details" open>
          <summary>Example response</summary>
          <pre><code>{JSON.stringify(responseExample, null, 2)}</code></pre>
        </details>
      )}
      <details class="schema-details">
        <summary>Response JSON Schema</summary>
        <pre><code>{JSON.stringify(responseSchema, null, 2)}</code></pre>
      </details>
    </div>
  )}
</div>
